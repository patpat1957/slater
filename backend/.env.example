# ─────────────────────────────────────────────────────────────
#  LottoPro — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Stripe Keys (https://dashboard.stripe.com/apikeys) ──────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Stripe Webhook Secret (https://dashboard.stripe.com/webhooks) ──
# Generated when you add a webhook endpoint in the Dashboard
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Stripe Price IDs (create in Dashboard → Products) ───────
# Pro Monthly
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXX
# Pro Annual  (20% off → $95.90/yr)
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXXXXXXXXXX
# Elite Monthly
STRIPE_PRICE_ELITE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXX
# Elite Annual  (20% off → $287.90/yr)
STRIPE_PRICE_ELITE_ANNUAL=price_XXXXXXXXXXXXXXXXXXXX

# ── App URLs ─────────────────────────────────────────────────
# Frontend base URL (used for Stripe redirect after checkout)
FRONTEND_URL=http://localhost:3010

# ── API security ─────────────────────────────────────────────
# Secret used to sign API keys issued to Pro/Elite users
API_KEY_SECRET=change_me_to_a_random_64_char_hex_string

# ── Optional: database URL (for production user persistence) ─
# DATABASE_URL=postgresql://user:password@localhost:5432/lottopro
